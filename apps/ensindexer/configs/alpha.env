# ENSIndexer named config: alpha (mainnet namespace)
#
# The "indexing identity" env vars for an alpha-style instance on the mainnet namespace — the values
# that feed Ponder's Build ID and therefore MUST match between the remote-checkpoint box and the
# deployed alpha (mainnet) Railway service for a warm-loaded schema to resume rather than re-index.
# See indexing-behavior-injection-contract.ts for what feeds the Build ID.
#
# Identity vars only: NAMESPACE, SUBGRAPH_COMPAT, PLUGINS, LABEL_SET_ID, LABEL_SET_VERSION.
# Deployment-specific vars (ENSDB_URL, ENSINDEXER_SCHEMA_NAME, ENSRAINBOW_URL, and an
# RPC_URL_<chainId> / provider key per indexed chain) are supplied per-environment and are NOT part
# of the identity.
#
# PLUGINS = EnvironmentDefaults.alpha (8) + efp. EFP is intentionally excluded from the shared alpha
# default in environment-defaults.ts because its datasources (EFPBase/EFPOptimism/EFPEthereum) exist
# only on the mainnet (and ens-test-env) namespaces; it is enabled here explicitly.
NAMESPACE=mainnet
SUBGRAPH_COMPAT=false
PLUGINS=subgraph,basenames,lineanames,threedns,protocol-acceleration,registrars,tokenscope,unigraph,efp
LABEL_SET_ID=searchlight
LABEL_SET_VERSION=1
