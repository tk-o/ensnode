# ENSIndexer named config: mainnet (subgraph-compatible)
#
# The "indexing identity" env vars for the subgraph-compatible mainnet instance — must match between
# the remote-checkpoint box and the deployed mainnet Railway service for a warm-loaded schema to
# resume rather than re-index. These mirror EnvironmentDefaults.subgraphCompatible.
#
# Identity vars only (see configs/alpha.env for the deployment-specific vars supplied separately).
NAMESPACE=mainnet
SUBGRAPH_COMPAT=true
PLUGINS=subgraph
LABEL_SET_ID=subgraph
LABEL_SET_VERSION=0
