---
/**
 * Omnigraph panel: GraphQL request is query + variables; result is a separate output section.
 */
import StaticExampleActionBar from "./StaticExampleActionBar.astro";
import StaticExampleCodeSection from "./StaticExampleCodeSection.astro";
import StaticExampleOutputSection from "./StaticExampleOutputSection.astro";

interface Props {
  uid: string;
  query: string;
  variablesJson: string;
  responseJson: string | null;
  adminUrl: string;
  hostedInstanceDocUrl: string;
  hostedInstanceLabel: string;
  responseSourceLabel: string;
}

const {
  uid,
  query,
  variablesJson,
  responseJson,
  adminUrl,
  hostedInstanceDocUrl,
  hostedInstanceLabel,
  responseSourceLabel,
} = Astro.props;
---

<StaticExampleActionBar
  variant="ensadmin"
  adminUrl={adminUrl}
  hostedInstanceDocUrl={hostedInstanceDocUrl}
  hostedInstanceLabel={hostedInstanceLabel}
/>

<StaticExampleCodeSection
  badge="GraphQL"
  headingId={`${uid}-query-heading`}
  code={query}
  lang="graphql"
/>

<StaticExampleCodeSection
  badge="Variables"
  headingId={`${uid}-variables-heading`}
  code={variablesJson}
  lang="json"
/>

{
  responseJson ? (
    <StaticExampleOutputSection
      uid={uid}
      responseJson={responseJson}
      responseSourceLabel={responseSourceLabel}
      responseSourceDocUrl={hostedInstanceDocUrl}
      heading="Output"
    />
  ) : null
}
