---
/** Tabs for mutually exclusive choices (e.g. npm vs pnpm), not request/response pairs. */
import { Code, Icon } from "@astrojs/starlight/components";

import type { StaticExampleTab, StaticExampleTabPanel } from "./tab-types";
import { staticExampleCodeWrapClass, staticExampleSectionXClass } from "./constants";

interface Props {
  tabsRootId: string;
  tablistAriaLabel: string;
  srHeading?: { id: string; label: string };
  tabs: StaticExampleTab[];
  panels: StaticExampleTabPanel[];
  tabButtonClass: string;
  tabIconClass?: string;
}

const { tabsRootId, tablistAriaLabel, srHeading, tabs, panels, tabButtonClass, tabIconClass } =
  Astro.props;

const tablistClass = "flex items-end gap-0 border-b border-black/[0.06] dark:border-white/[0.08]";
---

<section
  class={`py-5 ${staticExampleSectionXClass}`}
  {...srHeading ? { "aria-labelledby": srHeading.id } : {}}>
  {
    srHeading ? (
      <h3 id={srHeading.id} class="sr-only">
        {srHeading.label}
      </h3>
    ) : null
  }
  <div class="static-tabs flex flex-col" data-tabs-root={tabsRootId}>
    <div class={tablistClass} role="tablist" aria-label={tablistAriaLabel}>
      {
        tabs.map((tab, i) => (
          <button
            type="button"
            role="tab"
            id={`${tab.id}-btn`}
            aria-selected={i === 0 ? "true" : "false"}
            aria-controls={tab.id}
            data-tab-target={tab.id}
            class={tabButtonClass}>
            {tab.icon && tabIconClass ? (
              <Icon name={tab.icon} class={tabIconClass} size="1.125em" />
            ) : null}
            <span class="tab-label">{tab.label}</span>
          </button>
        ))
      }
    </div>
    <div class="relative">
      {
        panels.map((panel) => (
          <div
            id={panel.id}
            role="tabpanel"
            aria-labelledby={`${panel.id}-btn`}
            data-tab-panel={panel.id}
            class:list={["example-tab-panel pt-3", { hidden: !panel.visible }]}
            hidden={!panel.visible}>
            <div class={staticExampleCodeWrapClass}>
              <Code code={panel.code} lang={panel.lang} />
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
